-- Rogue Utility Hub

local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local mouse = player:GetMouse()

local char = player.Character or player.CharacterAdded:Wait()

player.CharacterAdded:Connect(function(c)
	char = c
end)

-- STATES

local flying=false
local noclip=false
local spectateTarget=nil
local attachBack=false
local flySpeed=80

-- GUI

local gui=Instance.new("ScreenGui",game.CoreGui)
gui.Name="RogueHub"

local frame=Instance.new("Frame",gui)
frame.Size=UDim2.new(0,260,0,420)
frame.Position=UDim2.new(0,20,0.5,-200)
frame.BackgroundColor3=Color3.fromRGB(25,25,25)

frame.Active=true
frame.Draggable=true

local title=Instance.new("TextLabel",frame)
title.Size=UDim2.new(1,0,0,30)
title.Text="Rogue Utility Hub"
title.BackgroundTransparency=1
title.TextColor3=Color3.new(1,1,1)

-- BUTTON CREATOR

local y=40

function makeButton(text,callback)

	local b=Instance.new("TextButton",frame)
	b.Size=UDim2.new(1,-10,0,30)
	b.Position=UDim2.new(0,5,0,y)
	b.Text=text
	b.BackgroundColor3=Color3.fromRGB(40,40,40)
	b.TextColor3=Color3.new(1,1,1)

	b.MouseButton1Click:Connect(callback)

	y=y+35

end

-- TELEPORT

local function teleportToMouse()

	if not char then return end

	local root=char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	local pos=mouse.Hit.Position

	root.CFrame=CFrame.new(pos+Vector3.new(0,5,0))

end

-- FLY

local bv
local bg

function startFly()

	local root=char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	bv=Instance.new("BodyVelocity",root)
	bv.MaxForce=Vector3.new(9e9,9e9,9e9)

	bg=Instance.new("BodyGyro",root)
	bg.MaxTorque=Vector3.new(9e9,9e9,9e9)

	RunService.RenderStepped:Connect(function()

		if not flying then return end

		local cam=workspace.CurrentCamera
		local dir=Vector3.new()

		if UIS:IsKeyDown(Enum.KeyCode.W) then
			dir=dir+cam.CFrame.LookVector
		end

		if UIS:IsKeyDown(Enum.KeyCode.S) then
			dir=dir-cam.CFrame.LookVector
		end

		if UIS:IsKeyDown(Enum.KeyCode.A) then
			dir=dir-cam.CFrame.RightVector
		end

		if UIS:IsKeyDown(Enum.KeyCode.D) then
			dir=dir+cam.CFrame.RightVector
		end

		bv.Velocity=dir*flySpeed
		bg.CFrame=cam.CFrame

	end)

end

function stopFly()

	if bv then bv:Destroy() end
	if bg then bg:Destroy() end

end

-- NOCLIP LOOP

RunService.Stepped:Connect(function()

	if noclip and char then

		for _,v in pairs(char:GetDescendants()) do
			if v:IsA("BasePart") then
				v.CanCollide=false
			end
		end

	end

end)

-- ATTACH LOOP

RunService.RenderStepped:Connect(function()

	if attachBack and spectateTarget and spectateTarget.Character then

		local root=char:FindFirstChild("HumanoidRootPart")
		local targetRoot=spectateTarget.Character:FindFirstChild("HumanoidRootPart")

		if root and targetRoot then
			root.CFrame=targetRoot.CFrame*CFrame.new(0,0,2)
		end

	end

end)

-- BUTTONS

makeButton("Fly (Y)",function()

	flying=not flying

	if flying then
		startFly()
	else
		stopFly()
	end

end)

makeButton("NoClip (N)",function()
	noclip=not noclip
end)

makeButton("Teleport To Mouse (T)",function()
	teleportToMouse()
end)

makeButton("WalkSpeed + (V)",function()

	local hum=char:FindFirstChildOfClass("Humanoid")
	if hum then
		hum.WalkSpeed=hum.WalkSpeed+10
	end

end)

makeButton("Reset WalkSpeed (B)",function()

	local hum=char:FindFirstChildOfClass("Humanoid")
	if hum then
		hum.WalkSpeed=16
	end

end)

makeButton("Attach To Back (P)",function()

	if spectateTarget then
		attachBack=not attachBack
	end

end)

-- SPECTATE MENU

local spectateFrame=Instance.new("Frame",frame)
spectateFrame.Size=UDim2.new(1,-10,0,120)
spectateFrame.Position=UDim2.new(0,5,1,-130)
spectateFrame.BackgroundColor3=Color3.fromRGB(30,30,30)

local layout=Instance.new("UIListLayout",spectateFrame)

function refreshSpectate()

	for _,v in pairs(spectateFrame:GetChildren()) do
		if v:IsA("TextButton") then
			v:Destroy()
		end
	end

	for _,plr in pairs(Players:GetPlayers()) do

		if plr~=player then

			local b=Instance.new("TextButton",spectateFrame)

			b.Size=UDim2.new(1,0,0,25)
			b.Text=plr.Name
			b.BackgroundColor3=Color3.fromRGB(40,40,40)
			b.TextColor3=Color3.new(1,1,1)

			b.MouseButton1Click:Connect(function()

				if spectateTarget==plr then

					spectateTarget=nil
					workspace.CurrentCamera.CameraSubject=char:FindFirstChildOfClass("Humanoid")

				else

					spectateTarget=plr

					if plr.Character then
						workspace.CurrentCamera.CameraSubject=plr.Character:FindFirstChildOfClass("Humanoid")
					end

				end

			end)

		end

	end

end

Players.PlayerAdded:Connect(refreshSpectate)
Players.PlayerRemoving:Connect(refreshSpectate)

refreshSpectate()

-- HOTKEYS

UIS.InputBegan:Connect(function(input,gp)

	if gp then return end

	if input.KeyCode==Enum.KeyCode.Y then
		flying=not flying
		if flying then startFly() else stopFly() end
	end

	if input.KeyCode==Enum.KeyCode.N then
		noclip=not noclip
	end

	if input.KeyCode==Enum.KeyCode.T then
		teleportToMouse()
	end

	if input.KeyCode==Enum.KeyCode.V then
		local hum=char:FindFirstChildOfClass("Humanoid")
		if hum then hum.WalkSpeed=hum.WalkSpeed+10 end
	end

	if input.KeyCode==Enum.KeyCode.B then
		local hum=char:FindFirstChildOfClass("Humanoid")
		if hum then hum.WalkSpeed=16 end
	end

	if input.KeyCode==Enum.KeyCode.P then
		if spectateTarget then
			attachBack=not attachBack
		end
	end

end)
